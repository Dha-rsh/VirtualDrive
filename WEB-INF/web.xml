<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="5.0">

<welcome-file-list>
<welcome-file>register.html</welcome-file>
</welcome-file-list>
<servlet>
<servlet-name>register</servlet-name>
<servlet-class>com.virtualdrive.controller.RegisterServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>register</servlet-name>
<url-pattern>/register</url-pattern>
</servlet-mapping>

<servlet>
<servlet-name>login</servlet-name>
<servlet-class>com.virtualdrive.controller.LoginServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>login</servlet-name>
<url-pattern>/login</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>FolderServlet</servlet-name>
    <servlet-class>com.virtualdrive.controller.FolderServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>FolderServlet</servlet-name>
    <url-pattern>/folder</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>FileUploadServlet</servlet-name>
    <servlet-class>com.virtualdrive.controller.FileUploadServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>FileUploadServlet</servlet-name>
    <url-pattern>/upload</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>Delete</servlet-name>
    <servlet-class>com.virtualdrive.controller.DeleteServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>Delete</servlet-name>
    <url-pattern>/delete</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeleteFolder</servlet-name>
    <servlet-class>com.virtualdrive.controller.DeleteFolderServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteFolder</servlet-name>
    <url-pattern>/deleteFolder</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>Download</servlet-name>
    <servlet-class>com.virtualdrive.controller.DownloadServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>Download</servlet-name>
    <url-pattern>/download</url-pattern>
</servlet-mapping>

</web-app>